    "next": "^15.0.0",
    "payload": "^3.60.0",
    "postgres": "^3.4.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-email": "^4.3.1",
    "react-hook-form": "^7.71.1",
    "react-parallax-tilt": "^1.7.314",
    "resend": "^6.2.0",
