{
  "name": "the-good-opal-co",
  "version": "1.0.0",
  "private": true,
  "description": "The Good Opal Co - Premium Jewelry & Opal Ecommerce Store",
  "author": "Dylan Henderson",
  "license": "MIT",
  "scripts": {
    "dev": "next dev -p 8412",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx,.js,.mjs",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\"",
    "test": "echo 'No unit tests configured. Use test:e2e for end-to-end tests.' && exit 0",
    "test:unit": "vitest",
    "test:unit:watch": "vitest watch",
    "test:unit:ui": "vitest --ui",
    "test:unit:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "validate": "pnpm type-check && pnpm lint",
    "validate:build": "pnpm type-check && pnpm lint && pnpm build",
    "prepare": "husky",
    "docker:up": "export DOCKER_HOST=unix://$HOME/.docker/run/docker.sock && docker compose up -d",
    "docker:down": "export DOCKER_HOST=unix://$HOME/.docker/run/docker.sock && docker compose down",
    "docker:logs": "export DOCKER_HOST=unix://$HOME/.docker/run/docker.sock && docker compose logs -f",
    "docker:clean": "export DOCKER_HOST=unix://$HOME/.docker/run/docker.sock && docker compose down -v",
    "docker:reset": "export DOCKER_HOST=unix://$HOME/.docker/run/docker.sock && docker compose down -v && docker compose up -d --build",
    "docker:ps": "export DOCKER_HOST=unix://$HOME/.docker/run/docker.sock && docker compose ps",
    "email": "email dev --dir src/emails --port 3002",
    "email:export": "email export",
    "seed": "tsx src/scripts/seed.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
