{
  "name": "the-good-opal-co",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "The Good Opal Co - Premium Jewelry & Opal Ecommerce Store",
  "author": "Dylan Henderson",
  "license": "MIT",
  "scripts": {
    "dev": "next dev -p 8412",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx,.js,.mjs",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\"",
    "test": "pnpm test:unit --run",
    "test:unit": "vitest",
    "test:unit:watch": "vitest watch",
    "test:unit:ui": "vitest --ui",
    "test:unit:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "validate": "pnpm type-check && pnpm lint",
    "validate:build": "pnpm type-check && pnpm lint && pnpm build",
    "prepare": "husky",
    "docker:up": "export DOCKER_HOST=unix://$HOME/.docker/run/docker.sock && docker compose up -d",
    "docker:down": "export DOCKER_HOST=unix://$HOME/.docker/run/docker.sock && docker compose down",
    "docker:logs": "export DOCKER_HOST=unix://$HOME/.docker/run/docker.sock && docker compose logs -f",
    "docker:clean": "export DOCKER_HOST=unix://$HOME/.docker/run/docker.sock && docker compose down -v",
    "docker:reset": "export DOCKER_HOST=unix://$HOME/.docker/run/docker.sock && docker compose down -v && docker compose up -d --build",
    "docker:ps": "export DOCKER_HOST=unix://$HOME/.docker/run/docker.sock && docker compose ps",
    "email": "email dev --dir src/emails --port 3002",
    "email:export": "email export",
    "seed": "node --env-file-if-exists=.env --env-file-if-exists=.env.local --import tsx src/scripts/seed.ts",
    "import:wordpress": "node --env-file-if-exists=.env --env-file-if-exists=.env.local --import tsx src/scripts/import-wordpress-content.ts",
    "import:wordpress-product-images": "node --env-file-if-exists=.env --env-file-if-exists=.env.local --import tsx src/scripts/import-wordpress-product-images.ts",
    "fallback:sync:woo": "node --env-file-if-exists=.env --env-file-if-exists=.env.local --import tsx scripts/sync-wordpress-product-fallback.ts",
    "catalog:sync:woo": "node --env-file-if-exists=.env --env-file-if-exists=.env.local --import tsx src/scripts/sync-woocommerce-catalog.ts",
    "import:woocommerce": "node --env-file-if-exists=.env --env-file-if-exists=.env.local --import tsx src/scripts/import-woocommerce-commerce.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@next/third-parties": "16.2.10",
    "@payloadcms/db-postgres": "^3.86.0",
    "@payloadcms/email-resend": "3.86.0",
    "@payloadcms/next": "^3.86.0",
    "@payloadcms/plugin-search": "^3.86.0",
    "@payloadcms/plugin-seo": "^3.86.0",
    "@payloadcms/richtext-lexical": "^3.86.0",
    "@payloadcms/storage-vercel-blob": "^3.86.0",
    "@payloadcms/ui": "3.86.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-toggle": "^1.1.14",
    "@radix-ui/react-toggle-group": "^1.1.15",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@stripe/stripe-js": "^8.1.0",
    "@upstash/redis": "1.35.8",
    "@vercel/analytics": "^1.5.0",
    "@vercel/blob": "2.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "framer-motion": "^12.23.25",
    "graphql": "^16.11.0",
    "lucide-react": "^0.546.0",
    "next": "16.2.10",
    "payload": "^3.86.0",
    "postgres": "^3.4.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.71.1",
    "resend": "^6.17.2",
    "sharp": "^0.34.4",
    "stripe": "22.3.1",
    "tailwind-merge": "^3.3.1",
    "three": "^0.185.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "16.2.10",
    "@playwright/test": "^1.56.1",
    "@remotion/cli": "^4.0.487",
    "@remotion/google-fonts": "^4.0.487",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.185.1",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.2.10",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "glob": "^13.0.0",
    "husky": "^9.1.7",
    "jsdom": "^27.0.0",
    "lint-staged": "^16.2.4",
    "postcss": "^8.4.47",
    "prettier": "^3.3.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "react-email": "^6.7.0",
    "remotion": "^4.0.487",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.20.6",
    "typescript": "^5.6.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22.0.0 <23",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "@babel/core": "7.29.6",
      "@esbuild-kit/core-utils>esbuild": "0.25.12",
      "dompurify": "3.4.11",
      "fast-uri": "3.1.2",
      "js-yaml": "4.2.0",
      "postcss": "8.5.16"
    }
  }
}
