{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "node scripts/vercel-build.mjs",
  "regions": ["syd1"],
  "functions": {
    "src/app/api/webhooks/stripe/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/cron/builder-mappings/route.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/inventory-reservations",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/woo-catalog",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/builder-mappings",
      "schedule": "7,22,37,52 * * * *"
    }
  ]
}
