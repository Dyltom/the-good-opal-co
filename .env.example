# Database
DATABASE_URL=postgresql://user:password@localhost:5432/goodopalco

# Payload CMS
PAYLOAD_SECRET=your-secret-key-minimum-32-characters-long-please
QUOTE_LINK_SECRET=generate-a-separate-random-secret-of-at-least-32-bytes
ADMIN_EMAIL=owner@your-verified-domain.com
# Required only until the first Production admin exists. Generate at least 16
# random characters, use it as that first user's password, then remove it and
# change the admin password.
# ADMIN_BOOTSTRAP_PASSWORD=

# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:8412
CRON_SECRET=generate-a-long-random-secret-for-vercel-cron
WOO_CATALOG_SYNC_ENABLED=false
# Optional: opal photo proposals processed per 15-minute cron run (1-25).
BUILDER_MAPPING_BATCH_SIZE=10

# Email (Resend - REQUIRED for contact/newsletter)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM="The Good Opal Co <noreply@your-verified-domain.com>"
CONTACT_EMAIL=orders@your-verified-domain.com
# Set true only after this sender reaches a real non-Resend recipient.
EMAIL_DELIVERY_VERIFIED=false

# Stripe (REQUIRED for ecommerce payments)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# Vercel Blob (REQUIRED for production CMS uploads)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxx

# Upstash Redis (REQUIRED for production abuse protection)
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# Analytics (optional)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=

# One-time legacy WooCommerce import (remove from Vercel after the import deployment)
# WOO_BASE_URL=https://legacy-store.example
# WOO_ADMIN_USERNAME=
# WOO_ADMIN_PASSWORD=
# WOO_IMPORT_ON_DEPLOY=false
# Gallery-only recovery switch. Remove after the successful deployment.
# WORDPRESS_PRODUCT_IMAGES_ON_DEPLOY=false
# Required with WOO_IMPORT_ON_DEPLOY=true. Never reuse an ID, including after failure.
# WOO_IMPORT_RUN_ID=final-delta-YYYYMMDD-01
# WOO_IMPORT_MODE=final-delta
